<?xml version="1.0"?>
<component name="nuxeo.labs.dynamic.fields.core.types">

  <!-- Make sure the default definitions (core scheas, core types) are loaded first -->
  <require>org.nuxeo.ecm.core.CoreExtensions</require>

  <!-- Schema: custom-schema-def (prefix csd) — field definitions per customer/type -->
  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="schema">
    <schema name="custom-schema-def" prefix="csd" src="schemas/custom-schema-def.xsd" />
    <schema name="dynamic-fields" prefix="dynf" src="schemas/dynamic-fields.xsd" />
  </extension>

  <!-- Document type: CustomSchemaDef — holds a customer's field definitions for a given type -->
  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="doctype">
    <doctype name="CustomSchemaDef" extends="Document">
      <schema name="uid" />
      <schema name="dublincore" />
      <schema name="common" />
      <facet name="Versionable"/>
      <facet name="Commentable"/>
      <facet name="HasRelatedText"/>
      <schema name="custom-schema-def" />
    </doctype>
  </extension>

  <!-- Document type: CustomSchemaDefContainer — to hold CustomSchemaDef documents -->
  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="doctype">
    <doctype name="CustomSchemaDefContainer" extends="Folder">
      <schema name="uid" />
      <schema name="dublincore" />
      <schema name="common" />
      <facet name="Commentable"/>
      <!-- Create CustomSchemaDef only in a container-->
      <subtypes>
        <type>CustomSchemaDef</type>
      </subtypes>
    </doctype>

    <!-- Where can we create a CustomSchemaDefContainer document?  We add to the definition -->
    <doctype name="Root" append="true">
      <subtypes>
        <type>CustomSchemaDefContainer</type>
      </subtypes>
    </doctype>
    <doctype name="Domain" append="true">
      <subtypes>
        <type>CustomSchemaDefContainer</type>
      </subtypes>
    </doctype>
    <doctype name="Workspace" append="true">
      <subtypes>
        <type>CustomSchemaDefContainer</type>
      </subtypes>
    </doctype>
    <doctype name="Folder" append="true">
      <subtypes>
        <type>CustomSchemaDefContainer</type>
      </subtypes>
    </doctype>
  </extension>

  <!-- Facet: DynamicFields — attach to any document that carries dynamic field values -->
  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="doctype">
    <facet name="DynamicFields">
      <schema name="dynamic-fields" />
    </facet>
  </extension>

  <!-- Icons and all about each document type -->
  <extension target="org.nuxeo.ecm.platform.types.TypeService" point="types">
     <type id="CustomSchemaDef">
      <label>Custom Schema Definition</label>
      <icon>/img/CustomSchemaDef.png</icon>
      <bigIcon>/img/CustomSchemaDef.png</bigIcon>
      <description></description>
    </type>
    <type id="CustomSchemaDefContainer">
      <label>Custom Schema Definition Container</label>
      <icon>/img/CustomSchemaDefContainer.png</icon>
      <bigIcon>/img/CustomSchemaDefContainer.png</bigIcon>
      <description></description>
    </type>
  </extension>

</component>
