<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:nxs="http://www.nuxeo.org/ecm/schemas/custom-schema-def"
           xmlns:nxsv="http://www.nuxeo.org/ecm/schemas/core/validation/"
           targetNamespace="http://www.nuxeo.org/ecm/schemas/custom-schema-def">

  <xs:element name="customerId" type="xs:string" nxsv:nillable="false" />
  <xs:element name="defForTyp" type="xs:string" nxsv:nillable="false" />

  <xs:complexType name="fieldDefinition">
    <xs:sequence>
      <xs:element name="fieldName" type="xs:string" />
      <xs:element name="fieldTyp" type="xs:string" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="fieldDefinitionList">
    <xs:sequence>
      <xs:element name="item" type="nxs:fieldDefinition" minOccurs="0" maxOccurs="unbounded" />
    </xs:sequence>
  </xs:complexType>

  <xs:element name="definition" type="nxs:fieldDefinitionList" />

</xs:schema>
